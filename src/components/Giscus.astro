<div class="giscus"></div>

<script is:inline>
  function loadGiscus() {
    const existing = document.querySelector('.giscus-frame');
    if (existing) existing.remove();

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', 'jeff-mos-def/jeffcamacho-micro');
    script.setAttribute('data-repo-id', 'R_kgDONJ7V_g');
    script.setAttribute('data-category', 'Announcements');
    script.setAttribute('data-category-id', 'DIC_kwDONJ7V_s4Cj8wh');
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'bottom');
    script.setAttribute('data-theme', 'dark');
    script.setAttribute('data-lang', 'en');
    script.crossOrigin = 'anonymous';
    script.async = true;
    document.querySelector('.giscus').appendChild(script);
  }

  loadGiscus();
  document.addEventListener('astro:after-swap', loadGiscus);
</script>