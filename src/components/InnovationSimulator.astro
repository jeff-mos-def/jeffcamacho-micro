---
// InnovationSimulator.astro
// A dynamic widget comparing In-The-Flow vs Innovation Period innovation.
---

<div class="my-8 mx-auto max-w-3xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 transition-all duration-300">
  <div class="text-center mb-6">
    <h3 class="text-xl font-bold text-slate-900 dark:text-white m-0">The Innovation Engine Simulator</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Toggle between modes to see how constraints shift your outcomes.</p>
  </div>

  <div class="flex justify-center space-x-2 p-1 bg-slate-100 dark:bg-slate-800 rounded-xl mb-6 max-w-md mx-auto">
    <button 
      id="btn-flow" 
      data-mode="flow"
      class="w-1/2 py-2 px-4 rounded-lg text-sm font-semibold transition-all duration-200 bg-white text-blue-600 shadow-sm dark:bg-slate-700 dark:text-blue-400"
    >
      🏎️ In-The-Flow (Sprints)
    </button>
    <button 
      id="btn-period" 
      data-mode="period"
      class="w-1/2 py-2 px-4 rounded-lg text-sm font-semibold transition-all duration-200 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-200"
    >
      🔬 Innovation Period (Sandbox)
    </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-5 gap-6 items-center min-h-[250px]">
    
    <div class="md:col-span-2 flex flex-col items-center justify-center p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl h-full border border-dashed border-slate-200 dark:border-slate-700">
      <div id="visual-icon" class="text-6xl transition-transform duration-500 transform ease-out animate-bounce">
        🏎️
      </div>
      <div id="visual-status" class="mt-4 text-xs font-mono uppercase tracking-wider text-blue-500 bg-blue-50 dark:bg-blue-950/50 px-2 py-1 rounded">
        Exploitation Mode
      </div>
    </div>

    <div class="md:col-span-3 space-y-4">
      <div>
        <span class="text-xs font-bold uppercase tracking-wide text-slate-400">Core Mandate</span>
        <p id="text-mandate" class="text-lg font-medium text-slate-800 dark:text-slate-200 mt-0.5">
          "Tuning the car while on the track." Optimize what is already working.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <span class="text-xs font-bold uppercase tracking-wide text-slate-400">Primary Constraint</span>
          <p id="text-constraint" class="text-sm font-semibold text-slate-700 dark:text-slate-300 mt-0.5">
            🔒 The Sprint Goal
          </p>
        </div>
        <div>
          <span class="text-xs font-bold uppercase tracking-wide text-slate-400">Acceptable Failure Risk</span>
          <p id="text-risk" class="text-sm font-semibold text-red-500 mt-0.5">
            📉 Low (Must deliver value)
          </p>
        </div>
      </div>

      <div class="pt-2 border-t border-slate-100 dark:border-slate-800">
        <button 
          id="btn-simulate"
          class="w-full py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg text-sm shadow transition-colors"
        >
          Test an Unplanned Idea
        </button>
        <div id="simulation-output" class="hidden mt-3 p-3 bg-emerald-50 dark:bg-emerald-950/30 text-emerald-800 dark:text-emerald-300 text-sm rounded-lg border border-emerald-100 dark:border-emerald-900/50">
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  // Dynamic Configuration Matrix
  const configs = {
    flow: {
      icon: "🏎️",
      status: "Exploitation Mode",
      statusClass: ["text-blue-500", "bg-blue-50", "dark:bg-blue-950/50"],
      removeStatusClass: ["text-amber-500", "bg-amber-50", "dark:bg-amber-950/50"],
      mandate: `"Tuning the car while on the track." Optimize, refine, and polish what is already known to deliver immediate value.`,
      constraint: "🔒 The Sprint Goal",
      risk: "📉 Low (Must deliver value)",
      riskClass: "text-red-500",
      removeRiskClass: "text-amber-500",
      btnClass: "bg-blue-600 hover:bg-blue-700",
      removeBtnClass: "bg-amber-600 hover:bg-amber-700",
      simulationPool: [
        "Success! Refactored API call to be 15% faster. It fits nicely inside the user story.",
        "Blocked. An idea arose to switch the core framework, but it was set aside to hit the Sprint Goal.",
        "Success! Automated a validation step, saving the tester 10 minutes per build."
      ]
    },
    period: {
      icon: "🔬",
      status: "Exploration Mode",
      statusClass: ["text-amber-500", "bg-amber-50", "dark:bg-amber-950/50"],
      removeStatusClass: ["text-blue-500", "bg-blue-50", "dark:bg-blue-950/50"],
      mandate: `"Redesigning the engine in the lab." Try unproven tech, tackle major system re-architectures, or build moonshot prototypes.`,
      constraint: "🔓 Infinite Possibilities (No Backlog)",
      risk: "🔥 High (Failure is learning)",
      riskClass: "text-amber-500",
      removeRiskClass: "text-red-500",
      btnClass: "bg-amber-600 hover:bg-amber-700",
      removeBtnClass: "bg-blue-600 hover:bg-blue-700",
      simulationPool: [
        "Failure! The prototype database setup crashed completely. Lesson learned: it's not ready for our infrastructure yet.",
        "Breakthrough! Spent 2 days testing a localized AI module. This could become a cornerstone feature next quarter!",
        "Clean Up! Paid down 2 years of legacy logging debt. Development velocity is expected to tick upward."
      ]
    }
  };

  let currentMode = 'flow';

  const btnFlow = document.getElementById('btn-flow');
  const btnPeriod = document.getElementById('btn-period');
  const visualIcon = document.getElementById('visual-icon');
  const visualStatus = document.getElementById('visual-status');
  const textMandate = document.getElementById('text-mandate');
  const textConstraint = document.getElementById('text-constraint');
  const textRisk = document.getElementById('text-risk');
  const btnSimulate = document.getElementById('btn-simulate');
  const simOutput = document.getElementById('simulation-output');

  function updateUI(mode) {
    currentMode = mode;
    const config = configs[mode];
    
    // Toggle active tab styles
    if (mode === 'flow') {
      btnFlow.className = "w-1/2 py-2 px-4 rounded-lg text-sm font-semibold transition-all duration-200 bg-white text-blue-600 shadow-sm dark:bg-slate-700 dark:text-blue-400";
      btnPeriod.className = "w-1/2 py-2 px-4 rounded-lg text-sm font-semibold transition-all duration-200 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-200";
    } else {
      btnPeriod.className = "w-1/2 py-2 px-4 rounded-lg text-sm font-semibold transition-all duration-200 bg-white text-amber-600 shadow-sm dark:bg-slate-700 dark:text-amber-400";
      btnFlow.className = "w-1/2 py-2 px-4 rounded-lg text-sm font-semibold transition-all duration-200 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-200";
    }

    // Update textual contents
    visualIcon.textContent = config.icon;
    visualStatus.textContent = config.status;
    textMandate.innerHTML = config.mandate;
    textConstraint.textContent = config.constraint;
    textRisk.textContent = config.risk;
    
    // Manage dynamic color classes
    visualStatus.classList.remove(...config.removeStatusClass);
    visualStatus.classList.add(...config.statusClass);
    
    textRisk.classList.remove(config.removeRiskClass);
    textRisk.classList.add(config.riskClass);
    
    btnSimulate.className = `w-full py-2.5 px-4 text-white font-medium rounded-lg text-sm shadow transition-colors ${config.btnClass}`;
    
    // Reset output block
    simOutput.classList.add('hidden');
    
    // Add a satisfying animation pop to the icon
    visualIcon.classList.remove('animate-bounce');
    void visualIcon.offsetWidth; // Trigger reflow to restart animation
    visualIcon.classList.add('animate-bounce');
  }

  // Event Listeners
  btnFlow.addEventListener('click', () => updateUI('flow'));
  btnPeriod.addEventListener('click', () => updateUI('period'));

  btnSimulate.addEventListener('click', () => {
    const currentPool = configs[currentMode].simulationPool;
    const randomResult = currentPool[Math.floor(Math.random() * currentPool.length)];
    
    simOutput.textContent = randomResult;
    simOutput.classList.remove('hidden');

    // Dynamically color outputs based on success or managed failure themes
    if (currentMode === 'flow') {
      simOutput.className = "mt-3 p-3 text-sm rounded-lg border bg-blue-50 dark:bg-blue-950/30 text-blue-800 dark:text-blue-300 border-blue-100 dark:border-blue-900/50";
    } else {
      if (randomResult.startsWith("Failure!")) {
        simOutput.className = "mt-3 p-3 text-sm rounded-lg border bg-red-50 dark:bg-red-950/30 text-red-800 dark:text-red-300 border-red-100 dark:border-red-900/50";
      } else {
        simOutput.className = "mt-3 p-3 text-sm rounded-lg border bg-amber-50 dark:bg-amber-950/30 text-amber-800 dark:text-amber-300 border-amber-100 dark:border-amber-900/50";
      }
    }
  });
</script>