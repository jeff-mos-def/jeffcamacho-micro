---
// WSJFComparator.astro
// Tight two-card ratio comparator to prove the value efficiency concept
// Drop into src/components/ and import into the post with:
// import WSJFComparator from '../../components/WSJFComparator.astro'
---

<div class="wsjf-comparator">
  <div class="wsjf-grid">
    <div class="wsjf-card" data-card="a">
      <div class="wsjf-card-label">Feature A</div>

      <div class="wsjf-input-group">
        <label for="value-a">Value</label>
        <input
          type="number"
          id="value-a"
          class="wsjf-input"
          data-field="value"
          data-card="a"
          min="0"
          step="1"
          value="8"
        />
      </div>

      <div class="wsjf-input-group">
        <label for="effort-a">Effort</label>
        <input
          type="number"
          id="effort-a"
          class="wsjf-input"
          data-field="effort"
          data-card="a"
          min="1"
          step="1"
          value="13"
        />
      </div>

      <div class="wsjf-ratio-block">
        <div class="wsjf-ratio-label">Value ÷ Effort</div>
        <div class="wsjf-ratio" data-ratio="a">0.62</div>
      </div>
    </div>

    <div class="wsjf-divider" aria-hidden="true">
      <span>vs</span>
    </div>

    <div class="wsjf-card" data-card="b">
      <div class="wsjf-card-label">Feature B</div>

      <div class="wsjf-input-group">
        <label for="value-b">Value</label>
        <input
          type="number"
          id="value-b"
          class="wsjf-input"
          data-field="value"
          data-card="b"
          min="0"
          step="1"
          value="5"
        />
      </div>

      <div class="wsjf-input-group">
        <label for="effort-b">Effort</label>
        <input
          type="number"
          id="effort-b"
          class="wsjf-input"
          data-field="effort"
          data-card="b"
          min="1"
          step="1"
          value="3"
        />
      </div>

      <div class="wsjf-ratio-block">
        <div class="wsjf-ratio-label">Value ÷ Effort</div>
        <div class="wsjf-ratio" data-ratio="b">1.67</div>
      </div>
    </div>
  </div>

  <div class="wsjf-verdict" data-verdict>
    <span class="wsjf-verdict-label">Ship first:</span>
    <span class="wsjf-verdict-winner" data-winner>Feature B</span>
    <span class="wsjf-verdict-reason" data-reason>Higher value per unit of effort</span>
  </div>
</div>

<style>
  .wsjf-comparator {
    font-family: inherit;
    margin: 2rem 0;
    padding: 1.5rem;
    border: 1px solid rgba(128, 128, 128, 0.2);
    border-radius: 8px;
    background: rgba(128, 128, 128, 0.03);
  }

  .wsjf-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: stretch;
  }

  .wsjf-card {
    padding: 1.25rem;
    border: 1px solid rgba(128, 128, 128, 0.25);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .wsjf-card.wsjf-winner {
    border-color: #3fa66a;
    box-shadow: 0 0 0 1px #3fa66a inset;
  }

  .wsjf-card-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .wsjf-input-group {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .wsjf-input-group label {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .wsjf-input {
    width: 80px;
    padding: 0.4rem 0.6rem;
    font-size: 0.95rem;
    font-family: inherit;
    text-align: right;
    border: 1px solid rgba(128, 128, 128, 0.35);
    border-radius: 4px;
    background: transparent;
    color: inherit;
  }

  .wsjf-input:focus {
    outline: none;
    border-color: #3fa66a;
    box-shadow: 0 0 0 2px rgba(63, 166, 106, 0.2);
  }

  .wsjf-ratio-block {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(128, 128, 128, 0.25);
    text-align: center;
  }

  .wsjf-ratio-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
    margin-bottom: 0.25rem;
  }

  .wsjf-ratio {
    font-size: 1.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .wsjf-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
    padding: 0 0.5rem;
  }

  .wsjf-verdict {
    margin-top: 1.25rem;
    padding: 0.9rem 1rem;
    background: rgba(63, 166, 106, 0.08);
    border-left: 3px solid #3fa66a;
    border-radius: 4px;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.95rem;
  }

  .wsjf-verdict-label {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    opacity: 0.75;
  }

  .wsjf-verdict-winner {
    font-weight: 700;
    color: #3fa66a;
  }

  .wsjf-verdict-reason {
    opacity: 0.7;
    font-size: 0.85rem;
  }

  @media (max-width: 600px) {
    .wsjf-grid {
      grid-template-columns: 1fr;
    }

    .wsjf-divider {
      padding: 0.5rem 0;
    }
  }
</style>

<script>
  (function () {
    const comparators = document.querySelectorAll('.wsjf-comparator');

    comparators.forEach((root) => {
      const inputs = root.querySelectorAll<HTMLInputElement>('.wsjf-input');
      const ratioA = root.querySelector<HTMLElement>('[data-ratio="a"]');
      const ratioB = root.querySelector<HTMLElement>('[data-ratio="b"]');
      const cardA = root.querySelector<HTMLElement>('[data-card="a"]');
      const cardB = root.querySelector<HTMLElement>('[data-card="b"]');
      const winnerEl = root.querySelector<HTMLElement>('[data-winner]');
      const reasonEl = root.querySelector<HTMLElement>('[data-reason]');

      function getVal(card: string, field: string): number {
        const el = root.querySelector<HTMLInputElement>(
          `.wsjf-input[data-card="${card}"][data-field="${field}"]`
        );
        return el ? Number(el.value) || 0 : 0;
      }

      function update() {
        const va = getVal('a', 'value');
        const ea = getVal('a', 'effort');
        const vb = getVal('b', 'value');
        const eb = getVal('b', 'effort');

        const ra = ea > 0 ? va / ea : 0;
        const rb = eb > 0 ? vb / eb : 0;

        if (ratioA) ratioA.textContent = ra.toFixed(2);
        if (ratioB) ratioB.textContent = rb.toFixed(2);

        cardA?.classList.remove('wsjf-winner');
        cardB?.classList.remove('wsjf-winner');

        if (!winnerEl || !reasonEl) return;

        if (ra === rb) {
          winnerEl.textContent = 'Tie';
          reasonEl.textContent = 'Equal value per unit of effort';
        } else if (ra > rb) {
          cardA?.classList.add('wsjf-winner');
          winnerEl.textContent = 'Feature A';
          reasonEl.textContent = 'Higher value per unit of effort';
        } else {
          cardB?.classList.add('wsjf-winner');
          winnerEl.textContent = 'Feature B';
          reasonEl.textContent = 'Higher value per unit of effort';
        }
      }

      inputs.forEach((input) => {
        input.addEventListener('input', update);
      });

      update();
    });
  })();
</script>
