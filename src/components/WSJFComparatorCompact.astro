---
// WSJFComparatorCompact.astro
// Two-card ratio comparator with Value vs Effort quadrant
// Axes use index position on SAFe modified Fibonacci scale (1,2,3,5,8,13,20,40,100)
// so step-to-step movement is visually uniform.
---

<div class="wsjfc">
  <div class="wsjfc-grid">
    <div class="wsjfc-cards">
      <div class="wsjfc-card" data-card="a">
        <div class="wsjfc-card-head">
          <span class="wsjfc-dot wsjfc-dot-a" aria-hidden="true"></span>
          <span class="wsjfc-card-label">Feature A</span>
        </div>

        <div class="wsjfc-input-row">
          <label>Value</label>
          <select class="wsjfc-input" data-field="value" data-card="a">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="5">5</option>
            <option value="8" selected>8</option>
            <option value="13">13</option>
            <option value="20">20</option>
            <option value="40">40</option>
            <option value="100">100</option>
          </select>
        </div>

        <div class="wsjfc-input-row">
          <label>Effort</label>
          <select class="wsjfc-input" data-field="effort" data-card="a">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="5">5</option>
            <option value="8">8</option>
            <option value="13" selected>13</option>
            <option value="20">20</option>
            <option value="40">40</option>
            <option value="100">100</option>
          </select>
        </div>

        <div class="wsjfc-ratio-row">
          <span class="wsjfc-ratio-label">V ÷ E</span>
          <span class="wsjfc-ratio" data-ratio="a">0.62</span>
        </div>
      </div>

      <div class="wsjfc-card" data-card="b">
        <div class="wsjfc-card-head">
          <span class="wsjfc-dot wsjfc-dot-b" aria-hidden="true"></span>
          <span class="wsjfc-card-label">Feature B</span>
        </div>

        <div class="wsjfc-input-row">
          <label>Value</label>
          <select class="wsjfc-input" data-field="value" data-card="b">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="5" selected>5</option>
            <option value="8">8</option>
            <option value="13">13</option>
            <option value="20">20</option>
            <option value="40">40</option>
            <option value="100">100</option>
          </select>
        </div>

        <div class="wsjfc-input-row">
          <label>Effort</label>
          <select class="wsjfc-input" data-field="effort" data-card="b">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3" selected>3</option>
            <option value="5">5</option>
            <option value="8">8</option>
            <option value="13">13</option>
            <option value="20">20</option>
            <option value="40">40</option>
            <option value="100">100</option>
          </select>
        </div>

        <div class="wsjfc-ratio-row">
          <span class="wsjfc-ratio-label">V ÷ E</span>
          <span class="wsjfc-ratio" data-ratio="b">1.67</span>
        </div>
      </div>
    </div>

    <div class="wsjfc-chart-wrap">
      <svg class="wsjfc-chart" viewBox="0 0 240 240" preserveAspectRatio="xMidYMid meet" aria-label="Value vs Effort quadrant">
        <!-- Plot area: 30,10 to 230,210 (200x200).
             Axes are normalized 0-10 scales. Quadrant split at 5 (midpoint = 130, 110).
             Fibonacci inputs (1-100) are mapped logarithmically to the 0-10 scale
             so visual spacing is uniform and no input value lands on the divider. -->
        <rect x="30"  y="10"  width="100" height="100" class="q q-do-first" />
        <rect x="130" y="10"  width="100" height="100" class="q q-big-bets" />
        <rect x="30"  y="110" width="100" height="100" class="q q-fill-ins" />
        <rect x="130" y="110" width="100" height="100" class="q q-reconsider" />

        <!-- Quadrant dividers -->
        <line x1="130" y1="10"  x2="130" y2="210" class="q-axis" />
        <line x1="30"  y1="110" x2="230" y2="110" class="q-axis" />

        <!-- Plot area border -->
        <rect x="30" y="10" width="200" height="200" class="q-border" />

        <!-- Quadrant labels -->
        <text x="80"  y="24"  class="q-label">Do first</text>
        <text x="180" y="24"  class="q-label">Big bets</text>
        <text x="80"  y="204" class="q-label">Fill-ins</text>
        <text x="180" y="204" class="q-label">Reconsider</text>

        <!-- Axis labels -->
        <text x="14"  y="110" class="q-axis-label" text-anchor="middle" transform="rotate(-90 14 110)">Value →</text>
        <text x="130" y="232" class="q-axis-label" text-anchor="middle">Effort →</text>

        <!-- Endpoint tick labels: Low / High on each axis -->
        <text x="30"  y="222" class="q-tick" text-anchor="middle">Low</text>
        <text x="230" y="222" class="q-tick" text-anchor="middle">High</text>
        <text x="26"  y="212" class="q-tick" text-anchor="end">Low</text>
        <text x="26"  y="14"  class="q-tick" text-anchor="end">High</text>

        <!-- Points (positions set by JS) -->
        <circle data-point="a" cx="170" cy="70" r="5" class="wsjfc-point wsjfc-point-a" />
        <circle data-point="b" cx="70"  cy="130" r="5" class="wsjfc-point wsjfc-point-b" />
      </svg>
    </div>
  </div>

  <div class="wsjfc-verdict">
    <span class="wsjfc-verdict-label">Ship first:</span>
    <span class="wsjfc-verdict-winner" data-winner>Feature B</span>
    <span class="wsjfc-verdict-reason" data-reason>Higher value per unit of effort</span>
  </div>
</div>

<style>
  .wsjfc {
    font-family: inherit;
    margin: 2rem 0;
    padding: 1.25rem;
    border: 1px solid rgba(128, 128, 128, 0.2);
    border-radius: 8px;
    background: rgba(128, 128, 128, 0.03);
  }

  .wsjfc-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .wsjfc-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .wsjfc-card {
    padding: 0.75rem;
    border: 1px solid rgba(128, 128, 128, 0.25);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.2s ease;
  }

  .wsjfc-card.wsjfc-winner {
    border-color: #3fa66a;
    box-shadow: 0 0 0 1px #3fa66a inset;
  }

  .wsjfc-card-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .wsjfc-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .wsjfc-dot-a { background: #4a9eff; }
  .wsjfc-dot-b { background: #f0a030; }

  .wsjfc-card-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.85;
  }

  .wsjfc-input-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  .wsjfc-input-row label {
    font-weight: 500;
  }

  .wsjfc-input {
    width: 72px;
    padding: 0.25rem 0.4rem;
    font-size: 0.85rem;
    font-family: inherit;
    text-align: right;
    border: 1px solid rgba(128, 128, 128, 0.35);
    border-radius: 4px;
    background: transparent;
    color: inherit;
    appearance: auto;
  }

  .wsjfc-input option {
    background: #ffffff;
    color: #1a1a1a;
  }

  .wsjfc-input:focus {
    outline: none;
    border-color: #3fa66a;
    box-shadow: 0 0 0 2px rgba(63, 166, 106, 0.2);
  }

  .wsjfc-ratio-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-top: 0.25rem;
    padding-top: 0.4rem;
    border-top: 1px dashed rgba(128, 128, 128, 0.25);
  }

  .wsjfc-ratio-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
  }

  .wsjfc-ratio {
    font-size: 1.1rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .wsjfc-chart-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wsjfc-chart {
    width: 100%;
    max-width: 260px;
    height: auto;
    aspect-ratio: 1 / 1;
  }

  .q { opacity: 0.85; }
  .q-do-first    { fill: rgba(63, 166, 106, 0.18); }
  .q-big-bets    { fill: rgba(74, 158, 255, 0.15); }
  .q-fill-ins    { fill: rgba(240, 160, 48, 0.15); }
  .q-reconsider  { fill: rgba(220, 80, 80, 0.15); }

  .q-axis {
    stroke: rgba(128, 128, 128, 0.45);
    stroke-width: 0.75;
  }

  .q-border {
    fill: none;
    stroke: rgba(128, 128, 128, 0.35);
    stroke-width: 0.75;
  }

  .q-label {
    font-size: 8px;
    font-weight: 600;
    fill: currentColor;
    opacity: 0.75;
    text-anchor: middle;
    font-family: inherit;
  }

  .q-axis-label {
    font-size: 8px;
    font-weight: 600;
    fill: currentColor;
    opacity: 0.7;
    font-family: inherit;
  }

  .q-tick {
    font-size: 6.5px;
    fill: currentColor;
    opacity: 0.55;
    font-family: inherit;
    font-variant-numeric: tabular-nums;
  }

  .wsjfc-point {
    stroke: #0b0d10;
    stroke-width: 1.5;
    transition: cx 0.25s ease, cy 0.25s ease;
  }

  .wsjfc-point-a { fill: #4a9eff; }
  .wsjfc-point-b { fill: #f0a030; }

  .wsjfc-verdict {
    margin-top: 1rem;
    padding: 0.6rem 0.85rem;
    background: rgba(63, 166, 106, 0.08);
    border-left: 3px solid #3fa66a;
    border-radius: 4px;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
  }

  .wsjfc-verdict-label {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.7rem;
    opacity: 0.75;
  }

  .wsjfc-verdict-winner {
    font-weight: 700;
    color: #3fa66a;
  }

  .wsjfc-verdict-reason {
    opacity: 0.7;
    font-size: 0.8rem;
  }

  @media (max-width: 640px) {
    .wsjfc-grid {
      grid-template-columns: 1fr;
    }

    .wsjfc-chart {
      max-width: 300px;
    }
  }
</style>

<script>
  (function () {
    const roots = document.querySelectorAll('.wsjfc');

    // SAFe modified Fibonacci inputs, mapped to a clean 0-10 normalized axis using log scaling.
    // The log spacing means each Fibonacci step takes a roughly equal visual distance,
    // and no Fibonacci value lands on the quadrant divider (midpoint of axis).
    const FIB = [1, 2, 3, 5, 8, 13, 20, 40, 100];
    const LOG_MAX = Math.log(100); // log(highest value)

    // Plot area: x from 30 to 230, y from 10 to 210 (200x200 box)
    const PLOT_X_MIN = 30;
    const PLOT_X_MAX = 230;
    const PLOT_Y_MIN = 10;
    const PLOT_Y_MAX = 210;
    const PLOT_W = PLOT_X_MAX - PLOT_X_MIN; // 200
    const PLOT_H = PLOT_Y_MAX - PLOT_Y_MIN; // 200

    function normalize(v: number): number {
      // log-scale normalized to 0..1
      if (v <= 1) return 0;
      if (v >= 100) return 1;
      return Math.log(v) / LOG_MAX;
    }

    function plotX(effort: number): number {
      // Inset slightly from edges so points at 1 or 100 aren't on the border
      const n = normalize(effort);
      return PLOT_X_MIN + 10 + n * (PLOT_W - 20);
    }

    function plotY(value: number): number {
      // Y inverted: higher value = lower y pixel
      const n = normalize(value);
      return PLOT_Y_MAX - 10 - n * (PLOT_H - 20);
    }

    roots.forEach((root) => {
      const inputs = root.querySelectorAll<HTMLSelectElement>('.wsjfc-input');
      const ratioA = root.querySelector<HTMLElement>('[data-ratio="a"]');
      const ratioB = root.querySelector<HTMLElement>('[data-ratio="b"]');
      const cardA = root.querySelector<HTMLElement>('[data-card="a"]');
      const cardB = root.querySelector<HTMLElement>('[data-card="b"]');
      const pointA = root.querySelector<SVGCircleElement>('[data-point="a"]');
      const pointB = root.querySelector<SVGCircleElement>('[data-point="b"]');
      const winnerEl = root.querySelector<HTMLElement>('[data-winner]');
      const reasonEl = root.querySelector<HTMLElement>('[data-reason]');

      function getVal(card: string, field: string): number {
        const el = root.querySelector<HTMLSelectElement>(
          `.wsjfc-input[data-card="${card}"][data-field="${field}"]`
        );
        return el ? Number(el.value) || 0 : 0;
      }

      function update() {
        const va = getVal('a', 'value');
        const ea = getVal('a', 'effort');
        const vb = getVal('b', 'value');
        const eb = getVal('b', 'effort');

        const ra = ea > 0 ? va / ea : 0;
        const rb = eb > 0 ? vb / eb : 0;

        if (ratioA) ratioA.textContent = ra.toFixed(2);
        if (ratioB) ratioB.textContent = rb.toFixed(2);

        if (pointA) {
          pointA.setAttribute('cx', String(plotX(ea)));
          pointA.setAttribute('cy', String(plotY(va)));
        }
        if (pointB) {
          pointB.setAttribute('cx', String(plotX(eb)));
          pointB.setAttribute('cy', String(plotY(vb)));
        }

        cardA?.classList.remove('wsjfc-winner');
        cardB?.classList.remove('wsjfc-winner');

        if (!winnerEl || !reasonEl) return;

        if (ra === rb) {
          winnerEl.textContent = 'Tie';
          reasonEl.textContent = 'Equal value per unit of effort';
        } else if (ra > rb) {
          cardA?.classList.add('wsjfc-winner');
          winnerEl.textContent = 'Feature A';
          reasonEl.textContent = 'Higher value per unit of effort';
        } else {
          cardB?.classList.add('wsjfc-winner');
          winnerEl.textContent = 'Feature B';
          reasonEl.textContent = 'Higher value per unit of effort';
        }
      }

      inputs.forEach((input) => {
        input.addEventListener('change', update);
      });

      update();
    });
  })();
</script>